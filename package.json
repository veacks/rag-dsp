{
  "name": "flowise-dsp-rag",
  "version": "1.0.0",
  "description": "Build OpenAI-embedded RAG indices, export vectors, upsert to Flowise, and browse chunks locally.",
  "type": "module",
  "bin": {
    "rager": "./bin/rager.mjs"
  },
  "files": [
    "bin",
    "scripts",
    "public",
    "rag-chat-flow",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node bin/rager.mjs flowise",
    "build:rag": "node bin/rager.mjs build",
    "export:vectors": "node bin/rager.mjs export",
    "upsert:flowise": "node bin/rager.mjs upsert",
    "serve:rag": "node bin/rager.mjs serve"
  },
  "keywords": [
    "rag",
    "flowise",
    "openai",
    "embeddings",
    "vector",
    "pdf",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/openai": "^1.4.4",
    "@langchain/textsplitters": "^1.0.1",
    "@napi-rs/canvas": "^0.1.99",
    "dotenv": "^16.6.1",
    "flowise": "^3.1.2",
    "langchain": "^1.3.3",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "serve": "^14.2.4"
  }
}
