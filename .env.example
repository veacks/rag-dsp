OPENAI_API_KEY=sk-...
# Crawl: one http(s) URL per line in ./sources/sites.txt (lines starting with # ignored).
# If this file has at least one URL, the build indexes those pages first, then merges local course assets (PDF + MAT + .ipynb) (see RAG_MERGE_PDFS).
# SITES_TXT=./sources/sites.txt
# RAG_IGNORE_SITES_TXT=1   # skip URL crawl; PDF-only from RAG_SOURCE_DIR / DEFAULT_PDF_DIR / PDF_PATH
# RAG_MERGE_PDFS=1         # after URL crawl, also index local course assets (PDF + MAT + .ipynb) (default 1). Set 0 for URLs only.
# RAG_LOCAL_RESOURCE_NAME=dsp-course-materials
# RAG_MERGE_TRANSCRIPTS=1  # merge local transcript text files (default 1)
# RAG_TRANSCRIPTS_DIR=./sources/transcripts/youtube
# CRAWL_DELAY_MS=400       # pause between requests (ms)
# CRAWL_MAX_PAGES_PER_SITE=300  # per seed URL, follow same-origin links up to this many pages
# RAG_PDF_RESOURCE_DIR=./sources/pdf/resources  # where crawled PDF files are saved locally
# YOUTUBE_URLS_TXT=./sources/youtube.txt
# YOUTUBE_TRANSCRIPT_DELAY_MS=350
# Single PDF if sites list is empty/ignored and ./pdf has no PDFs (default ./DesigningAudioEffectPlugins.pdf)
# PDF_PATH=./path/to/your.pdf
# Optional: override the PDF folder (default ./pdf when that folder exists).
# If `RAG_SOURCE_DIR` or `SOURCE_DIR` is set, it wins; `DEFAULT_PDF_DIR` is used only when those are unset.
# Path must be a directory — not `.../*.pdf` (all *.pdf, *.mat, and *.ipynb under the tree are discovered automatically).
# DEFAULT_PDF_DIR=./sources/pdf
# RAG_SOURCE_DIR=./content/pdfs
# Base URL for metadata.url on PDF chunks (no trailing slash); crawled pages use their real URL
# SITE_BASE_URL=https://example.com
#
# Rich PDF build (pdf.js: layout, tables/code heuristics, image crops, optional vision). Omit for default rich pipeline.
# RAG_PDF_LEGACY=1          # use pdf-parse text-only + plain chunking (fast, no assets)
# RAG_PDF_VISION=1          # OpenAI vision on figure crops (cost)
# RAG_VISION_MODEL=gpt-4o-mini
# RAG_PDF_MAX_FIGURES=24    # max figure crops + vision calls per PDF
# RAG_PDF_RENDER_SCALE=1.5  # pdf.js page raster scale (embedded crops + full-page PNGs under public/rag-assets/)
# Optional: scripts/export-vector-db.mjs (defaults shown)
# RAG_PATH=./public/rag.json
# EXPORT_DIR=./packages/core/ragdataset
#
# Flowise upsert (npm run upsert:flowise) — import rag-chat-flow/*.json in UI, then:
# FLOWISE_BASE_URL=http://127.0.0.1:3000
# FLOWISE_CHATFLOW_ID=<uuid from Flowise>
# FLOWISE_API_KEY=<Bearer from API Keys, same workspace as chatflow>
# FLOWISE_FLOW_JSON=./rag-chat-flow/rag-dsp-chatlow.json   # optional: read stopNodeId
# FLOWISE_STOP_NODE_ID=memoryVectorStore_0                 # optional if several vector nodes
